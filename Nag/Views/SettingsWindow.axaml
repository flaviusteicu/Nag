<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Nag.Views.SettingsWindow"
        Title="Settings — Nag" 
        SizeToContent="Height" 
        Width="380"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E" 
        Foreground="#EEEEEE"
        CanResize="False" 
        FontFamily="Inter">
    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#EEEEEE"/>
        </Style>
        <Style Selector="Label">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,5,0,5"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2ECC71"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#29b765"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="10,4,10,4"/>
        </Style>
        <!-- Force TimePicker internal flyout button to respect our width -->
        <Style Selector="TimePicker /template/ Button#PART_FlyoutButton">
            <Setter Property="MinWidth" Value="0"/>
        </Style>
        <Style Selector="TimePicker">
            <Setter Property="MinWidth" Value="0"/>
        </Style>
    </Window.Styles>
    
    <Panel>
        <!-- Main scrollable content -->
        <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
            
            <!-- Frequency -->
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <Label Content="Notification Frequency"/>
                <RadioButton Content="Light (1–2 per day)" Margin="0,5,0,5" GroupName="Freq" IsChecked="{Binding IsFreqLight}" />
                <RadioButton Content="Moderate (3–5 per day)" Margin="0,0,0,5" GroupName="Freq" IsChecked="{Binding IsFreqModerate}" />
                <RadioButton Content="Intensive (5–10 per day)" Margin="0,0,0,5" GroupName="Freq" IsChecked="{Binding IsFreqIntensive}" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <RadioButton Content="Custom range limit: " GroupName="Freq" VerticalAlignment="Center" IsChecked="{Binding IsFreqCustom}"/>
                    <ComboBox Width="72" Height="20" MaxDropDownHeight="250" Margin="5,0,0,0" IsEnabled="{Binding IsFreqCustom}" VerticalAlignment="Center" ItemsSource="{Binding CustomFreqOptions}" SelectedItem="{Binding CustomFreqMin}" />
                    <TextBlock Text=" to " VerticalAlignment="Center" Margin="5,0,5,0" Foreground="#EEEEEE" />
                    <ComboBox Width="72" Height="20" MaxDropDownHeight="250" IsEnabled="{Binding IsFreqCustom}" VerticalAlignment="Center" ItemsSource="{Binding CustomFreqOptions}" SelectedItem="{Binding CustomFreqMax}" />
                </StackPanel>
                
                <!-- Raffle Weights UI Trigger -->
                <Button Content="Adjust Category Weights..." HorizontalAlignment="Stretch"
                        Background="#111A30" Foreground="#2ECC71" BorderThickness="1" BorderBrush="#2ECC71" 
                        Height="30" Cursor="Hand" Command="{Binding AdjustWeightsCommand}" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- Active Hours -->
            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <Label Content="Active Hours (24h format)" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                    <TimePicker Width="130" SelectedTime="{Binding ActiveHoursStartTimeSpan, Mode=TwoWay}" ClockIdentifier="24HourClock" ToolTip.Tip="{Binding ActiveHoursStartTooltip}"/>
                    <TextBlock Text="to" VerticalAlignment="Center" Foreground="#888888"/>
                    <TimePicker Width="130" SelectedTime="{Binding ActiveHoursEndTimeSpan, Mode=TwoWay}" ClockIdentifier="24HourClock" ToolTip.Tip="{Binding ActiveHoursEndTooltip}"/>
                </StackPanel>
            </StackPanel>

            <!-- Duration -->
            <StackPanel Grid.Row="2" Margin="0,0,0,15">
                <Label>
                    <TextBlock><Run Text="Notification Duration ("/><Run Text="{Binding NotificationDurationSeconds}"/><Run Text="s)"/></TextBlock>
                </Label>
                <Slider Minimum="5" Maximum="30" Value="{Binding NotificationDurationSeconds}" 
                        TickFrequency="1" IsSnapToTickEnabled="True"/>
            </StackPanel>

            <!-- Start with Windows (hidden on non-Windows where Registry startup isn't available) -->
            <StackPanel Grid.Row="3" Margin="0,0,0,20" IsVisible="{Binding IsStartupSupported}">
                <CheckBox Content="Start with System" IsChecked="{Binding StartWithWindows}"/>
            </StackPanel>

            <!-- Import Custom Pack -->
            <Button Grid.Row="4" Content="Import Custom Pack..." 
                    Background="#111A30" Foreground="#2ECC71" BorderThickness="1" BorderBrush="#2ECC71" 
                    Height="30" Cursor="Hand" Command="{Binding ImportPackCommand}" Margin="0,0,0,15" HorizontalAlignment="Stretch"/>

            <!-- Buttons -->
            <Button Grid.Row="5" Content="Save Settings" 
                    Background="#2ECC71" Foreground="White" BorderThickness="0" 
                    Height="35" FontWeight="SemiBold" Cursor="Hand" Command="{Binding SaveCommand}" HorizontalAlignment="Stretch"/>

            <Button Grid.Row="6" Content="Preview Notification" 
                    Background="#16213E" Foreground="#888888" BorderThickness="1" BorderBrush="#888888" 
                    Height="30" Cursor="Hand" Command="{Binding PreviewCommand}" Margin="0,15,0,0" HorizontalAlignment="Stretch"/>
        </Grid>
        
        <!-- Floating icons top-right, overlaid on top of the form -->
        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,15,15,0" Spacing="15">
            <Image Source="avares://Nag/app_logo.png" Width="90" Height="90" HorizontalAlignment="Center" ToolTip.Tip="Nag"/>
            <Button Width="32" Height="32" Cursor="Hand" ToolTip.Tip="Open Settings Folder" 
                    Command="{Binding OpenFolderCommand}" Background="#16213E" BorderBrush="#444444" BorderThickness="1"
                    CornerRadius="16" HorizontalAlignment="Center">
                <TextBlock Text="📁" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
        </StackPanel>
    </Panel>
</Window>

